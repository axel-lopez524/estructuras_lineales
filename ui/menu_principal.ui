  <property name="styleSheet">
   <string notr="true">/* ===== QMainWindow ===== */
QMainWindow {
    background-color: #0F172A;
}

/* ===== QWidget ===== */
QWidget {
    background-color: #0F172A;
    color: #F8FAFC;
    font-family: &quot;Segoe UI&quot;;
    font-size: 10pt;
}

/* ===== Menu Bar ===== */
QMenuBar {
    background-color: #1E293B;
    color: white;
    border-bottom: 2px solid #22C55E;
    padding: 4px;
}

QMenuBar::item {
    background: transparent;
    padding: 8px 15px;
    border-radius: 5px;
}

QMenuBar::item:selected {
    background-color: #2563EB;
    color: white;
}

QMenuBar::item:pressed {
    background-color: #1D4ED8;
}

/* ===== Menús desplegables ===== */
QMenu {
    background-color: #1E293B;
    color: white;
    border: 1px solid #22C55E;
    padding: 5px;
}

QMenu::item {
    padding: 8px 25px;
    border-radius: 4px;
}

QMenu::item:selected {
    background-color: #22C55E;
    color: #0F172A;
}

QMenu::separator {
    height: 1px;
    background: #334155;
    margin: 5px 10px;
}

/* ===== Acciones ===== */
QAction {
    color: white;
}

/* ===== Botones ===== */
QPushButton {
    background-color: #2563EB;
    color: white;
    border: none;
    border-radius: 8px;
    padding: 8px 15px;
    font-weight: bold;
}

QPushButton:hover {
    background-color: #3B82F6;
}

QPushButton:pressed {
    background-color: #1D4ED8;
}

/* ===== Campos de texto ===== */
QLineEdit, QTextEdit, QPlainTextEdit {
    background-color: #1E293B;
    border: 2px solid #334155;
    border-radius: 8px;
    padding: 5px;
    color: white;
}

QLineEdit:focus, QTextEdit:focus {
    border: 2px solid #22C55E;
}

/* ===== Tablas ===== */
QTableWidget {
    background-color: #1E293B;
    alternate-background-color: #273449;
    gridline-color: #334155;
    color: white;
    border: 1px solid #334155;
}

QHeaderView::section {
    background-color: #2563EB;
    color: white;
    padding: 6px;
    border: none;
    font-weight: bold;
}

/* ===== Barra de estado ===== */
QStatusBar {
    background-color: #1E293B;
    color: white;
    border-top: 2px solid #22C55E;
}
</string>
